{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier --write \"resources/**/*.{css,ts,tsx}\" vite.config.ts eslint.config.js tsconfig.json",
        "format:check": "prettier --check \"resources/**/*.{css,ts,tsx}\" vite.config.ts eslint.config.js tsconfig.json",
        "lint": "eslint resources/js/admin resources/js/public vite.config.ts eslint.config.js --max-warnings=0",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.31.0",
        "@headlessui/react": "^2.2.4",
        "@inertiajs/react": "^2.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^24.0.13",
        "@types/react": "^18.3.23",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^4.2.0",
        "axios": "^1.11.0",
        "clsx": "^2.1.1",
        "concurrently": "^9.0.1",
        "eslint": "^9.31.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^16.3.0",
        "laravel-vite-plugin": "^2.0.0",
        "motion": "^12.23.12",
        "prettier": "^3.6.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^4.1.11",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.37.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@tiptap/extension-link": "^3.27.1",
        "@tiptap/react": "^3.27.1",
        "@tiptap/starter-kit": "^3.27.1",
        "lucide-react": "^1.23.0",
        "react-icons": "^5.7.0",
        "sharp": "^0.35.3",
        "swiper": "^14.0.1"
    }
